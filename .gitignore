###############################################################################
# TwinCAT 3 C++ (and future TwinCAT) projects
#
# Source of truth that MUST be committed: .tsproj, .xti, .vcxproj(+filters),
# .props, .tmc (the module description is hand-maintained source in C++
# projects!), all .cpp/.h/.c, .rc, .slnx/.sln
###############################################################################

# --- Visual Studio user/session state ---------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# --- TwinCAT C++ build output ------------------------------------------------
# TMX/TME binaries and all MSVC intermediates land under _products\
_products/
*.tmx
*.tme

# --- TwinCAT generated/derived folders ---------------------------------------
_Boot/
_CompileInfo/
_Libraries/
_ModuleInstall/

# --- TwinCAT PLC derived files (for future mixed projects) -------------------
*.tpy
*.tclrs
*.compiled-library
*.compileinfo
LineIDs.dbg

# --- Backups and dumps --------------------------------------------------------
*.bak
*.tcdmp

# --- C/C++ build intermediates (incl. the PC simulation in
#     LegacyFirmware_Original — rebuild with build_sim.ps1) -------------------
*.obj
*.pch
*.ipch
*.pdb
*.idb
*.ilk
*.exp
*.iobj
*.ipdb
*.tlog
*.lastbuildstate
*.exe

# --- Logs and temp ------------------------------------------------------------
*.log
*.tmp
