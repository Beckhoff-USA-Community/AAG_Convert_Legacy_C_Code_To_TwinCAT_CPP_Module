          <mxGeometry x="440" y="400" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p3_e1" value="Enable" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=1;exitY=0.25;entryX=0;entryY=0.25;" edge="1" parent="1" source="p3_idle" target="p3_ramp">
