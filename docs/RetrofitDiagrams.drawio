        <mxCell id="p3_e2" value="!Enable" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=0;exitY=0.75;entryX=1;entryY=0.75;" edge="1" parent="1" source="p3_ramp" target="p3_idle">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e3" value="|err| ≤ 1 °C for 0.5 s" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=1;exitY=0.25;entryX=0;entryY=0.25;" edge="1" parent="1" source="p3_ramp" target="p3_track">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e4" value="|err| &gt; 3 °C" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=0;exitY=0.75;entryX=1;entryY=0.75;" edge="1" parent="1" source="p3_track" target="p3_ramp">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e5" value="!Enable" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=0.5;exitY=0;entryX=0.5;entryY=0;" edge="1" parent="1" source="p3_track" target="p3_idle">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="875" y="80" />
              <mxPoint x="155" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_e6" value="T &gt; 110 °C for 0.1 s" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#b85450;fontColor=#b85450;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p3_ramp" target="p3_fault">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p3_e7" value="T &gt; 110 °C for 0.1 s" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;strokeColor=#b85450;fontColor=#b85450;exitX=0.5;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="p3_track" target="p3_fault">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="875" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="p3_e8" value="FaultReset ↑ edge  AND  T &lt; 100 °C" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=11;exitX=0;exitY=0.5;entryX=0.5;entryY=1;" edge="1" parent="1" source="p3_fault" target="p3_idle">
