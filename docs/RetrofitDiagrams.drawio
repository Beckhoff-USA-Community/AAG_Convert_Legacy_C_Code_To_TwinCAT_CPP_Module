  <diagram id="page2-porting-steps" name="2 Porting Steps">
    <mxGraphModel dx="900" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p2_start" value="Customer C code (.c / .h)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="325" y="40" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_s1" value="&lt;b&gt;1 · Audit&lt;/b&gt; — portable C99 compiles as-is.&lt;br&gt;List only OS / hardware / stdio calls: that list is the whole port." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="245" y="130" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_s2" value="&lt;b&gt;2 · Copy files&lt;/b&gt; into the C++ project unchanged&lt;br&gt;(e.g. legacy\) — Add → Existing Item" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="240" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2_s3" value="&lt;b&gt;3 · Per .c file:&lt;/b&gt; C/C++ → Precompiled Headers →&lt;br&gt;&lt;b&gt;&quot;Not Using Precompiled Headers&quot;&lt;/b&gt; (the only required setting)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="245" y="340" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2_s4" value="&lt;b&gt;4 · Include with C linkage&lt;/b&gt; in the module:&lt;br&gt;extern &quot;C&quot; { #include &quot;legacy/xyz.h&quot; }" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="440" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2_s5" value="&lt;b&gt;5 · Give state a home:&lt;/b&gt; context structs become module members;&lt;br&gt;call init() in SetObjStatePS, tuning from TMC parameters" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="540" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="p2_s6" value="&lt;b&gt;6 · Call step() from CycleUpdate()&lt;/b&gt;&lt;br&gt;dt = task cycle time; data areas replace the HAL" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="650" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2_s7" value="&lt;b&gt;7 · Build&lt;/b&gt;  (Release | TwinCAT RT (x64))" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="245" y="750" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p2_d1" value="Linker&lt;br&gt;errors?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="345" y="840" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="p2_fix" value="Map each unresolved symbol:&lt;br&gt;printf → m_Trace.Log&lt;br&gt;fopen → ITcFileAccess&lt;br&gt;per-cycle malloc → preallocate&lt;br&gt;threads → cyclic redesign" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="830" width="230" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p2_done" value="Done — signed TMX,&lt;br&gt;ready to activate" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="325" y="970" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p2_e0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p2_start" target="p2_s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p2_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p2_s1" target="p2_s2">
